{
  "$schema": "https://raw.githubusercontent.com/nicovrc/tauri-v2-schema/refs/tags/v2.5.0/tauri.conf.schema.json",
  "productName": "网络设备巡检系统",
  "version": "3.0.0",
  "identifier": "com.inspection.rust",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "网络设备巡检系统",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
